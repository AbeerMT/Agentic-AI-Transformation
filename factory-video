// ═══════════════════════════════════════════
// CONVEYOR BELT
// ═══════════════════════════════════════════
function conveyorBelt(x,y,w,h,offset=0){
  ctx.fillStyle='#5D4037';ctx.strokeStyle='#2C1810';ctx.lineWidth=2;
  ctx.beginPath();ctx.roundRect(x,y,w,h,6);ctx.fill();ctx.stroke();
  // belt stripes
  ctx.strokeStyle='#795548';ctx.lineWidth=3;
  for(let i=0;i<20;i++){
    const bx=x+(i*28+offset)%w;
    if(bx>x&&bx<x+w){ctx.beginPath();ctx.moveTo(bx,y+2);ctx.lineTo(bx,y+h-2);ctx.stroke();}
  }
  // rollers
  ctx.fillStyle='#9E9E9E';ctx.strokeStyle='#2C1810';ctx.lineWidth=2;
  ctx.beginPath();ctx.arc(x+h/2,y+h/2,h/2,0,Math.PI*2);ctx.fill();ctx.stroke();
  ctx.beginPath();ctx.arc(x+w-h/2,y+h/2,h/2,0,Math.PI*2);ctx.fill();ctx.stroke();
}

// ═══════════════════════════════════════════
// GEAR
// ═══════════════════════════════════════════
function gear(cx,cy,r,teeth,angle,col='#78909C'){
  ctx.save();ctx.translate(cx,cy);ctx.rotate(angle);
  ctx.fillStyle=col;ctx.strokeStyle='#2C1810';ctx.lineWidth=2;
  ctx.beginPath();
  for(let i=0;i<teeth*2;i++){
    const a=i*Math.PI/teeth, ri=i%2===0?r:r*0.68;
    i===0?ctx.moveTo(ri*Math.cos(a),ri*Math.sin(a)):ctx.lineTo(ri*Math.cos(a),ri*Math.sin(a));
  }
  ctx.closePath();ctx.fill();ctx.stroke();
  ctx.fillStyle='#455A64';ctx.beginPath();ctx.arc(0,0,r*0.32,0,Math.PI*2);ctx.fill();ctx.stroke();
  ctx.restore();
}

// ═══════════════════════════════════════════
// COMIC LABEL
// ═══════════════════════════════════════════
function comicLabel(text,x,y,col='#FF6B35',size=18){
  ctx.save();
  ctx.font=`bold ${size}px Fredoka One,cursive`;
  ctx.textAlign='center';
  ctx.strokeStyle='#2C1810';ctx.lineWidth=4;ctx.strokeText(text,x,y);
  ctx.fillStyle=col;ctx.fillText(text,x,y);
  ctx.restore();
}

function star(cx,cy,r,col='#FFD700'){
  ctx.save();ctx.translate(cx,cy);ctx.fillStyle=col;ctx.strokeStyle='#2C1810';ctx.lineWidth=1.5;
  ctx.beginPath();
  for(let i=0;i<10;i++){
    const a=i*Math.PI/5-Math.PI/2, ri=i%2===0?r:r*0.45;
    i===0?ctx.moveTo(ri*Math.cos(a),ri*Math.sin(a)):ctx.lineTo(ri*Math.cos(a),ri*Math.sin(a));
  }
  ctx.closePath();ctx.fill();ctx.stroke();ctx.restore();
}

