<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Factory Transformation — Cartoon Edition</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Fredoka+One&family=Nunito:wght@400;600;700;800;900&display=swap');

*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{
  --sky:#87CEEB; --grass:#5DBB63; --ground:#8B6914;
  --wall:#F5E6C8; --roof:#D2691E; --machine:#4A90D9;
  --belt:#8B4513; --yellow:#FFD700; --red:#FF4444;
  --green:#44BB44; --white:#FFFEF0; --dark:#2C1810;
  --comic:#FF6B35; --bubble:#FFFACD;
  --shadow:rgba(0,0,0,0.15);
}
html,body{width:100%;height:100%;background:#1a1a2e;font-family:'Nunito',sans-serif;overflow:hidden;}

#app{width:100vw;height:100vh;display:flex;flex-direction:column;position:relative;}

/* CANVAS */
#scene{flex:1;position:relative;overflow:hidden;cursor:pointer;}
canvas{position:absolute;inset:0;width:100%;height:100%;}

/* COMIC TITLE CARD */
#title-card{
  position:absolute;inset:0;
  display:flex;flex-direction:column;align-items:center;justify-content:center;
  background:var(--yellow);
  z-index:20;
  transition:transform 0.6s cubic-bezier(0.68,-0.55,0.27,1.55);
}
#title-card.gone{transform:translateY(-100%);}
#title-card h1{
  font-family:'Fredoka One',cursive;
  font-size:clamp(28px,5vw,64px);
  color:var(--dark);
  text-align:center;
  line-height:1.1;
  -webkit-text-stroke:2px var(--dark);
  filter:drop-shadow(4px 4px 0 var(--comic));
  padding:0 20px;
}
#title-card p{font-size:clamp(14px,2vw,22px);color:#555;margin-top:16px;font-weight:700;}
#title-card .start-btn{
  margin-top:32px;
  background:var(--comic);color:white;
  border:none;border-radius:50px;
  font-family:'Fredoka One',cursive;font-size:clamp(18px,2.5vw,28px);
  padding:14px 48px;cursor:pointer;
  box-shadow:0 6px 0 #c0392b, 0 8px 20px rgba(0,0,0,0.3);
  transition:transform 0.1s,box-shadow 0.1s;
}
#title-card .start-btn:hover{transform:translateY(3px);box-shadow:0 3px 0 #c0392b,0 5px 15px rgba(0,0,0,0.3);}
#title-card .stars{font-size:40px;letter-spacing:8px;margin-bottom:16px;}

/* SPEECH BUBBLE */
#speech{
  position:absolute;
  background:var(--bubble);
  border:3px solid var(--dark);
  border-radius:20px;
  padding:12px 18px;
  font-family:'Fredoka One',cursive;
  font-size:clamp(13px,1.8vw,20px);
  color:var(--dark);
  max-width:280px;
  text-align:center;
  pointer-events:none;
  opacity:0;
  transition:opacity 0.3s;
  z-index:10;
  box-shadow:3px 3px 0 var(--dark);
}
#speech::after{
  content:'';position:absolute;bottom:-18px;left:30px;
  border:10px solid transparent;
  border-top-color:var(--dark);
}
#speech::before{
  content:'';position:absolute;bottom:-13px;left:32px;
  border:8px solid transparent;
  border-top-color:var(--bubble);
  z-index:1;
}
#speech.show{opacity:1;}

/* COMIC EFFECT */
#comic-fx{
  position:absolute;
  font-family:'Fredoka One',cursive;
  font-size:clamp(32px,6vw,80px);
  color:var(--yellow);
  -webkit-text-stroke:3px var(--dark);
  filter:drop-shadow(4px 4px 0 var(--comic));
  pointer-events:none;
  opacity:0;
  transform:scale(0) rotate(-15deg);
  transition:all 0.25s cubic-bezier(0.68,-0.55,0.27,1.55);
  z-index:15;
}
#comic-fx.pop{opacity:1;transform:scale(1) rotate(-8deg);}

/* CHAPTER TITLE */
#chapter{
  position:absolute;top:0;left:0;right:0;
  background:var(--comic);
  color:white;
  font-family:'Fredoka One',cursive;
  font-size:clamp(16px,2.5vw,28px);
  text-align:center;
  padding:10px;
  border-bottom:4px solid var(--dark);
  transform:translateY(-100%);
  transition:transform 0.4s cubic-bezier(0.68,-0.55,0.27,1.55);
  z-index:8;
}
#chapter.show{transform:translateY(0);}

/* NARRATION */
#narration{
  position:absolute;bottom:70px;left:50%;transform:translateX(-50%);
  width:min(90%,800px);
  background:rgba(255,254,240,0.96);
  border:3px solid var(--dark);
  border-radius:16px;
  padding:14px 20px;
  font-size:clamp(13px,1.6vw,17px);
  font-weight:700;color:var(--dark);
  text-align:center;
  box-shadow:4px 4px 0 var(--dark);
  opacity:0;transition:opacity 0.4s;
  z-index:9;
}
#narration.show{opacity:1;}
#narration .narrator-tag{
  display:inline-block;
  background:var(--comic);color:white;
  font-family:'Fredoka One',cursive;
  font-size:11px;padding:2px 10px;border-radius:20px;
  margin-bottom:6px;letter-spacing:0.05em;
}

/* CONTROLS */
#controls{
  height:56px;
  background:#2C1810;
  border-top:4px solid var(--dark);
  display:flex;align-items:center;padding:0 16px;gap:12px;
  flex-shrink:0;
}
.cbtn{
  background:var(--yellow);border:3px solid var(--dark);
  color:var(--dark);font-family:'Fredoka One',cursive;font-size:14px;
  padding:6px 18px;border-radius:30px;cursor:pointer;
  box-shadow:3px 3px 0 var(--dark);
  transition:transform 0.1s,box-shadow 0.1s;
}
.cbtn:hover{transform:translate(2px,2px);box-shadow:1px 1px 0 var(--dark);}
.cbtn.play{background:var(--comic);color:white;}

/* PROGRESS */
#prog-wrap{flex:1;height:14px;background:#3d2a1a;border:2px solid var(--dark);border-radius:20px;overflow:hidden;}
#prog-fill{height:100%;background:linear-gradient(90deg,var(--yellow),var(--comic));border-radius:20px;width:0%;transition:width 0.3s;}

#timer{font-family:'Fredoka One',cursive;color:var(--yellow);font-size:15px;min-width:70px;}

/* SCENE DOTS */
#dots{display:flex;gap:8px;margin-left:8px;}
.sdot{width:14px;height:14px;border-radius:50%;background:#3d2a1a;border:2px solid #6b4c30;cursor:pointer;transition:all 0.2s;}
.sdot.active{background:var(--yellow);box-shadow:0 0 8px var(--yellow);}
.sdot.done{background:#6b4c30;}

/* METRICS POPUP */
#metrics-popup{
  position:absolute;top:60px;right:20px;
  background:white;border:3px solid var(--dark);border-radius:16px;
  padding:16px;min-width:190px;
  box-shadow:5px 5px 0 var(--dark);
  display:none;z-index:10;
  font-family:'Fredoka One',cursive;
}
#metrics-popup.show{display:block;animation:popIn 0.4s cubic-bezier(0.68,-0.55,0.27,1.55);}
@keyframes popIn{from{transform:scale(0);opacity:0;}to{transform:scale(1);opacity:1;}}
.mrow{display:flex;justify-content:space-between;align-items:center;margin-bottom:10px;padding-bottom:10px;border-bottom:2px dashed #eee;}
.mrow:last-child{margin:0;padding:0;border:none;}
.mlabel{font-size:13px;color:#666;}
.mval{font-size:22px;font-weight:900;}
.mval.bad{color:var(--red);}
.mval.ok{color:var(--comic);}
.mval.good{color:var(--green);}

/* THOUGHT BUBBLE */
.thought{
  position:absolute;
  background:white;border:3px solid var(--dark);border-radius:50%;
  display:flex;align-items:center;justify-content:center;
  font-size:clamp(16px,2.5vw,28px);
  text-align:center;padding:10px;
  box-shadow:3px 3px 0 var(--dark);
  animation:wobble 2s ease-in-out infinite;
  pointer-events:none;z-index:7;
}
@keyframes wobble{0%,100%{transform:rotate(-3deg);}50%{transform:rotate(3deg);}}
@keyframes bounce{0%,100%{transform:translateY(0);}50%{transform:translateY(-12px);}}
@keyframes spin{from{transform:rotate(0deg);}to{transform:rotate(360deg);}}
@keyframes shake{0%,100%{transform:translateX(0);}25%{transform:translateX(-6px);}75%{transform:translateX(6px);}}
</style>
</head>
<body>
<div id="app">

  <!-- TITLE CARD -->
  <div id="title-card">
    <div class="stars">⚙️ 💧 ⚡ 🏭 😅</div>
    <h1>Don't Just Swap the Engine.<br>Reimagine the Factory!</h1>
    <p>A 90-second animated lesson in industrial transformation</p>
    <button class="start-btn" onclick="startVideo()">▶ Let's Watch!</button>
  </div>

  <div id="scene">
    <canvas id="c"></canvas>
    <div id="chapter"></div>
    <div id="speech"></div>
    <div id="comic-fx"></div>
    <div id="narration"><span class="narrator-tag">📢 Narrator</span><br><span id="nar-text"></span></div>
    <div id="metrics-popup">
      <div class="mrow"><span class="mlabel">📦 Output</span><span class="mval" id="mv-out">—</span></div>
      <div class="mrow"><span class="mlabel">⚡ Energy</span><span class="mval" id="mv-eng">—</span></div>
      <div class="mrow"><span class="mlabel">🔧 Downtime</span><span class="mval" id="mv-dwn">—</span></div>
    </div>
  </div>

  <div id="controls">
    <button class="cbtn" onclick="prevScene()">◀ Back</button>
    <button class="cbtn play" id="playbtn" onclick="togglePlay()">⏸ Pause</button>
    <button class="cbtn" onclick="nextScene()">Next ▶</button>
    <div id="prog-wrap"><div id="prog-fill"></div></div>
    <div id="timer">0:00</div>
    <div id="dots"></div>
  </div>
</div>

<script>
// ═══════════════════════════════════════════
// CANVAS SETUP
// ═══════════════════════════════════════════
const cv = document.getElementById('c');
const ctx = cv.getContext('2d');
let W, H;

function resize(){
  const s = document.getElementById('scene');
  W = cv.width  = s.clientWidth;
  H = cv.height = s.clientHeight;
}
window.addEventListener('resize',()=>{resize();});
resize();

// ═══════════════════════════════════════════
// SCENE DATA
// ═══════════════════════════════════════════
const SCENES=[
{
  id:0, dur:15,
  title:"⚙️ Meet Bob's Factory (circa 1850)",
  narration:"Welcome to Bob's factory! Bob is very proud. Everything runs on one giant water wheel. It spins a shaft. The shaft spins EVERYTHING. Bob has no idea this will be a problem.",
  speech:"I love my water wheel! 💧", speechDelay:2,
  comicFx:"SPLASH!", comicDelay:1,
  type:'water', metrics:null
},
{
  id:1, dur:15,
  title:"🔗 The Shaft Problem",
  narration:"See those belts connecting every machine to the same shaft? If the shaft breaks — EVERYTHING stops. If you want to move a machine — you CAN'T. The layout is a prisoner of the engine.",
  speech:"Wait… I can't move my desk?! 😰", speechDelay:2,
  comicFx:"UH-OH!", comicDelay:4,
  type:'water_problem', metrics:null
},
{
  id:2, dur:18,
  title:"⚡ Bob Hears About Electricity!",
  narration:"The year is 1900. Bob hears about electric motors. 'AMAZING!' he says. 'I'll replace my water wheel with an electric motor — same shaft, same belts, same everything!' Bob is about to make a very predictable mistake.",
  speech:"Electric is the future! 🎉", speechDelay:1.5,
  comicFx:"ZAP! ⚡", comicDelay:3,
  type:'electric_swap', metrics:null
},
{
  id:3, dur:16,
  title:"😬 Bob's Disappointing Results",
  narration:"After the upgrade: Output up 2%. TWO PERCENT. Bob spent a fortune. His workers are confused. His boss is not happy. The machines are in the exact same spot. Nothing fundamentally changed.",
  speech:"...Just 2%? My bonus is gone. 😭", speechDelay:2,
  comicFx:"FACEPALM!", comicDelay:1,
  type:'bad_results',
  metrics:{out:'+2%',eng:'-18%',dwn:'-5%', outC:'bad', engC:'ok', dwnC:'ok'}
},
{
  id:4, dur:18,
  title:"💡 The Lightbulb Moment!",
  narration:"Then Bob's daughter — an engineer — visits. She says: 'Dad, with individual motors, EACH machine can go ANYWHERE. You don't need a shaft at all! Rethink the whole floor!' Bob's mind = blown. 🤯",
  speech:"Dad… the shaft is the problem! 💡", speechDelay:1.5,
  comicFx:"EUREKA!", comicDelay:3,
  type:'eureka', metrics:null
},
{
  id:5, dur:18,
  title:"🏆 The Reimagined Factory",
  narration:"New layout: machines arranged by workflow, not by shaft position. Each has its own motor. Parallel lines. Flexible cells. Output triples. Downtime drops 68%. Bob cries happy tears. His daughter gets promoted.",
  speech:"This is BEAUTIFUL! 😭🎊", speechDelay:3,
  comicFx:"WOW! 🚀", comicDelay:2,
  type:'reimagined',
  metrics:{out:'×3.4',eng:'-52%',dwn:'-68%', outC:'good', engC:'good', dwnC:'good'}
},
];

const TOTAL_DUR = SCENES.reduce((a,s)=>a+s.dur,0);

// ═══════════════════════════════════════════
// STATE
// ═══════════════════════════════════════════
let scene=0, sTime=0, totalTime=0, playing=false, lastTs=null, animT=0;
let particles=[], waterDrops=[], sparks=[];
let bobMood='happy', bobBounce=0, bobBounceV=0;
let started=false;

// ═══════════════════════════════════════════
// PARTICLES
// ═══════════════════════════════════════════
function addParticle(x,y,col,vx,vy,life,r,type='circle'){
  particles.push({x,y,col,vx,vy,life,maxLife:life,r,type});
}
function addSpark(x,y){
  for(let i=0;i<6;i++){
    const a=Math.random()*Math.PI*2, s=2+Math.random()*4;
    sparks.push({x,y,vx:Math.cos(a)*s,vy:Math.sin(a)*s-3,life:1,r:2+Math.random()*2});
  }
}
function addWaterDrop(x,y){
  waterDrops.push({x,y,vx:(Math.random()-0.5)*2,vy:-2-Math.random()*3,life:1});
}
function updateParticles(dt){
  particles=particles.filter(p=>p.life>0);
  particles.forEach(p=>{p.x+=p.vx;p.y+=p.vy;p.vy+=0.15;p.life-=dt;});
  sparks=sparks.filter(p=>p.life>0);
  sparks.forEach(p=>{p.x+=p.vx;p.y+=p.vy;p.vy+=0.2;p.life-=dt*1.5;});
  waterDrops=waterDrops.filter(p=>p.life>0);
  waterDrops.forEach(p=>{p.x+=p.vx;p.y+=p.vy;p.vy+=0.1;p.life-=dt*0.8;});
}
function drawParticles(){
  particles.forEach(p=>{
    ctx.save();ctx.globalAlpha=p.life/p.maxLife;ctx.fillStyle=p.col;
    ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fill();ctx.restore();
  });
  sparks.forEach(p=>{
    ctx.save();ctx.globalAlpha=p.life;
    ctx.fillStyle='#FFD700';ctx.shadowColor='#FFD700';ctx.shadowBlur=8;
    ctx.beginPath();ctx.arc(p.x,p.y,p.r,0,Math.PI*2);ctx.fill();ctx.restore();
  });
  waterDrops.forEach(p=>{
    ctx.save();ctx.globalAlpha=p.life*0.8;ctx.fillStyle='#4FC3F7';
    ctx.beginPath();
    ctx.ellipse(p.x,p.y,3,5,Math.PI*0.1,0,Math.PI*2);ctx.fill();ctx.restore();
  });
}

// ═══════════════════════════════════════════
// DRAWING HELPERS
// ═══════════════════════════════════════════
function sky(col1='#87CEEB',col2='#E0F4FF'){
  const g=ctx.createLinearGradient(0,0,0,H*0.55);
  g.addColorStop(0,col1);g.addColorStop(1,col2);
  ctx.fillStyle=g;ctx.fillRect(0,0,W,H*0.55);
}
function ground(){
  // ground strip
  ctx.fillStyle='#8B6914';ctx.fillRect(0,H*0.85,W,H*0.15);
  ctx.fillStyle='#5DBB63';ctx.fillRect(0,H*0.75,W,H*0.12);
  // grass tufts
  ctx.fillStyle='#4CAF50';
  for(let x=0;x<W;x+=40){
    const g=x*0.7%8;
    ctx.beginPath();ctx.moveTo(x,H*0.75);ctx.lineTo(x+8,H*0.75-10-g);ctx.lineTo(x+16,H*0.75);ctx.fill();
  }
}
function cloud(x,y,s=1){
  ctx.fillStyle='white';ctx.shadowColor='rgba(0,0,0,0.1)';ctx.shadowBlur=10;
  [[0,0,30],[25,-12,22],[50,0,28],[75,-8,20],[-20,5,20]].forEach(([dx,dy,r])=>{
    ctx.beginPath();ctx.arc(x+dx*s,y+dy*s,r*s,0,Math.PI*2);ctx.fill();
  });
  ctx.shadowBlur=0;
}

function factory(x,y,w,h,col='#F5E6C8'){
  // shadow
  ctx.fillStyle='rgba(0,0,0,0.1)';ctx.fillRect(x+8,y+h+2,w,12);
  // walls
  ctx.fillStyle=col;ctx.strokeStyle='#2C1810';ctx.lineWidth=3;
  ctx.beginPath();ctx.roundRect(x,y,w,h,4);ctx.fill();ctx.stroke();
  // roof
  ctx.fillStyle='#D2691E';ctx.strokeStyle='#2C1810';ctx.lineWidth=3;
  ctx.beginPath();ctx.moveTo(x-10,y);ctx.lineTo(x+w/2,y-30);ctx.lineTo(x+w+10,y);ctx.closePath();
  ctx.fill();ctx.stroke();
  // windows
  for(let i=0;i<3;i++){
    const wx=x+20+i*(w-30)/2.5;
    ctx.fillStyle='#B3E5FC';ctx.strokeStyle='#2C1810';ctx.lineWidth=2;
    ctx.fillRect(wx,y+20,28,28);ctx.strokeRect(wx,y+20,28,28);
    ctx.strokeStyle='#7BC8E2';
    ctx.beginPath();ctx.moveTo(wx+14,y+20);ctx.lineTo(wx+14,y+48);ctx.stroke();
    ctx.beginPath();ctx.moveTo(wx,y+34);ctx.lineTo(wx+28,y+34);ctx.stroke();
  }
  // door
  ctx.fillStyle='#8B4513';ctx.strokeStyle='#2C1810';ctx.lineWidth=2;
  ctx.beginPath();ctx.roundRect(x+w/2-18,y+h-60,36,60,4,4,0,0);ctx.fill();ctx.stroke();
  // chimney
  ctx.fillStyle='#8B4513';ctx.strokeStyle='#2C1810';ctx.lineWidth=2;
  ctx.fillRect(x+w-50,y-50,24,55);ctx.strokeRect(x+w-50,y-50,24,55);
}

function machine(x,y,w,h,col='#4A90D9',label='',animated=false,progress=0){
  // shadow
  ctx.fillStyle='rgba(0,0,0,0.12)';ctx.fillRect(x+4,y+h,w,8);
  // body
  ctx.fillStyle=col;ctx.strokeStyle='#2C1810';ctx.lineWidth=2.5;
  ctx.beginPath();ctx.roundRect(x,y,w,h,6);ctx.fill();ctx.stroke();
  // top highlight
  ctx.fillStyle='rgba(255,255,255,0.25)';
  ctx.beginPath();ctx.roundRect(x+4,y+4,w-8,12,3);ctx.fill();
  // screen
  ctx.fillStyle='#1a1a2e';ctx.beginPath();ctx.roundRect(x+8,y+18,w-16,h-38,4);ctx.fill();
  // screen content
  if(animated){
    ctx.fillStyle=`hsl(${(animT*120)%360},80%,65%)`;
    ctx.fillRect(x+12,y+22,((w-24)*progress),h-46);
  }
  // label
  ctx.fillStyle='white';ctx.font=`bold ${Math.min(12,w/5)}px Fredoka One, cursive`;
  ctx.textAlign='center';ctx.fillText(label,x+w/2,y+h-8);
  // legs
  ctx.fillStyle='#555';
  ctx.fillRect(x+8,y+h,8,10);ctx.fillRect(x+w-16,y+h,8,10);
}

function waterWheel(cx,cy,r,angle){
  ctx.save();ctx.translate(cx,cy);
  // water channel
  ctx.fillStyle='#1565C0';ctx.fillRect(-r-30,-r*1.5,22,r*2.5);
  ctx.fillStyle='#42A5F5';ctx.fillRect(-r-25,-r*1.4,14,r*2.3);
  // water drops
  if(Math.random()<0.08) addWaterDrop(cx-r-18,cy-r*0.8);
  // wheel
  ctx.rotate(angle);
  ctx.fillStyle='#5D4037';ctx.strokeStyle='#2C1810';ctx.lineWidth=3;
  ctx.beginPath();ctx.arc(0,0,r,0,Math.PI*2);ctx.fill();ctx.stroke();
  // spokes
  for(let i=0;i<6;i++){
    const a=i*Math.PI/3;
    ctx.strokeStyle='#8D6E63';ctx.lineWidth=5;
    ctx.beginPath();ctx.moveTo(0,0);ctx.lineTo(r*0.85*Math.cos(a),r*0.85*Math.sin(a));ctx.stroke();
  }
  // paddles
  for(let i=0;i<8;i++){
    const a=i*Math.PI/4;
    ctx.save();ctx.rotate(a);
    ctx.fillStyle='#795548';ctx.strokeStyle='#2C1810';ctx.lineWidth=2;
    ctx.fillRect(r*0.55,-8,r*0.38,16);ctx.strokeRect(r*0.55,-8,r*0.38,16);
    ctx.restore();
  }
  // hub
  ctx.fillStyle='#FFD700';ctx.strokeStyle='#2C1810';ctx.lineWidth=2;
  ctx.beginPath();ctx.arc(0,0,12,0,Math.PI*2);ctx.fill();ctx.stroke();
  ctx.restore();
}

function shaft(x1,y,x2){
  ctx.fillStyle='#9E9E9E';ctx.strokeStyle='#2C1810';ctx.lineWidth=2;
  ctx.fillRect(x1,y-7,x2-x1,14);ctx.strokeRect(x1,y-7,x2-x1,14);
  // shine
  ctx.fillStyle='rgba(255,255,255,0.3)';ctx.fillRect(x1,y-5,x2-x1,4);
  // rotation marks
  for(let x=x1+10;x<x2;x+=30){
    ctx.strokeStyle='#757575';ctx.lineWidth=1;
    ctx.beginPath();ctx.moveTo(x,y-7);ctx.lineTo(x,y+7);ctx.stroke();
  }
}

function belt(x1,y1,x2,y2,offset=0){
  ctx.strokeStyle='#5D4037';ctx.lineWidth=6;
  ctx.setLineDash([16,8]);ctx.lineDashOffset=-offset;
  ctx.beginPath();ctx.moveTo(x1,y1);ctx.lineTo(x2,y2);ctx.stroke();
  ctx.setLineDash([]);
}

function electricMotor(x,y,w,h,active=false){
  ctx.fillStyle='#1565C0';ctx.strokeStyle='#2C1810';ctx.lineWidth=2.5;
  ctx.beginPath();ctx.roundRect(x,y,w,h,8);ctx.fill();ctx.stroke();
  if(active){
    ctx.shadowColor='#FFD700';ctx.shadowBlur=20;
    ctx.strokeStyle='#FFD700';ctx.lineWidth=2;
    ctx.strokeRect(x+3,y+3,w-6,h-6);
    ctx.shadowBlur=0;
    // lightning
    const bx=x+w/2,by=y+h/2;
    ctx.fillStyle='#FFD700';
    ctx.beginPath();
    ctx.moveTo(bx,by-14);ctx.lineTo(bx-8,by);ctx.lineTo(bx-2,by);
    ctx.lineTo(bx,by+14);ctx.lineTo(bx+8,by);ctx.lineTo(bx+2,by);
    ctx.closePath();ctx.fill();
    if(Math.random()<0.04) addSpark(bx+w*0.4,by);
  }
  ctx.fillStyle='white';ctx.font='10px Fredoka One,cursive';
  ctx.textAlign='center';ctx.fillText('MOTOR',x+w/2,y+h+12);
}

// ═══════════════════════════════════════════
// BOB — cartoon character
// ═══════════════════════════════════════════
function drawBob(x,y,scale=1,mood='happy',hat=true){
  const s=scale;
  ctx.save();ctx.translate(x,y+bobBounce*s);

  // shadow
  ctx.fillStyle='rgba(0,0,0,0.12)';
  ctx.beginPath();ctx.ellipse(0,22*s,16*s,6*s,0,0,Math.PI*2);ctx.fill();

  // legs
  ctx.fillStyle='#37474F';
  ctx.fillRect(-14*s,0,11*s,22*s);ctx.fillRect(4*s,0,11*s,22*s);
  // shoes
  ctx.fillStyle='#1a1a1a';
  ctx.beginPath();ctx.ellipse(-8*s,22*s,10*s,5*s,0,0,Math.PI*2);ctx.fill();
  ctx.beginPath();ctx.ellipse(10*s,22*s,10*s,5*s,0,0,Math.PI*2);ctx.fill();

  // body
  const bodyCol = mood==='sad'?'#90A4AE': mood==='excited'?'#EF9A9A':'#5C8DC8';
  ctx.fillStyle=bodyCol;ctx.strokeStyle='#2C1810';ctx.lineWidth=2;
  ctx.beginPath();ctx.roundRect(-16*s,-38*s,32*s,40*s,6*s);ctx.fill();ctx.stroke();
  // tie
  ctx.fillStyle='#E53935';
  ctx.beginPath();ctx.moveTo(0,-36*s);ctx.lineTo(-4*s,-18*s);ctx.lineTo(0,-14*s);ctx.lineTo(4*s,-18*s);ctx.closePath();ctx.fill();

  // arms
  const armSwing = mood==='excited'?Math.sin(animT*8)*0.5:0.1;
  ctx.fillStyle=bodyCol;ctx.strokeStyle='#2C1810';ctx.lineWidth=2;
  ctx.save();ctx.translate(-16*s,-28*s);ctx.rotate(-0.3-armSwing);
  ctx.beginPath();ctx.roundRect(-6*s,0,12*s,24*s,4*s);ctx.fill();ctx.stroke();ctx.restore();
  ctx.save();ctx.translate(16*s,-28*s);ctx.rotate(0.3+armSwing);
  ctx.beginPath();ctx.roundRect(-6*s,0,12*s,24*s,4*s);ctx.fill();ctx.stroke();ctx.restore();

  // head
  ctx.fillStyle='#FFCC80';ctx.strokeStyle='#2C1810';ctx.lineWidth=2;
  ctx.beginPath();ctx.arc(0,-52*s,20*s,0,Math.PI*2);ctx.fill();ctx.stroke();

  // eyes
  const eyeOpen = mood==='sad'?0.4:1;
  ctx.fillStyle='white';
  ctx.beginPath();ctx.ellipse(-8*s,-54*s,6*s,7*s*eyeOpen,0,0,Math.PI*2);ctx.fill();
  ctx.beginPath();ctx.ellipse(8*s,-54*s,6*s,7*s*eyeOpen,0,0,Math.PI*2);ctx.fill();
  ctx.fillStyle='#1a1a1a';
  ctx.beginPath();ctx.arc(-8*s,-53*s,3*s,0,Math.PI*2);ctx.fill();
  ctx.beginPath();ctx.arc(8*s,-53*s,3*s,0,Math.PI*2);ctx.fill();
  // shine
  ctx.fillStyle='white';
  ctx.beginPath();ctx.arc(-6*s,-55*s,1.5*s,0,Math.PI*2);ctx.fill();
  ctx.beginPath();ctx.arc(10*s,-55*s,1.5*s,0,Math.PI*2);ctx.fill();

  // mouth
  ctx.strokeStyle='#2C1810';ctx.lineWidth=2;ctx.lineCap='round';
  if(mood==='happy'){
    ctx.beginPath();ctx.arc(0,-48*s,8*s,0.1,Math.PI-0.1);ctx.stroke();
  } else if(mood==='sad'){
    ctx.beginPath();ctx.arc(0,-42*s,8*s,Math.PI+0.1,-0.1);ctx.stroke();
  } else if(mood==='excited'){
    ctx.fillStyle='#1a1a1a';ctx.beginPath();ctx.arc(0,-48*s,8*s,0,Math.PI);ctx.fill();
    ctx.fillStyle='white';ctx.beginPath();ctx.arc(0,-48*s,5*s,0,Math.PI);ctx.fill();
  } else if(mood==='shocked'){
    ctx.fillStyle='#1a1a1a';ctx.beginPath();ctx.arc(0,-47*s,6*s,0,Math.PI*2);ctx.fill();
  }

  // hat
  if(hat){
    ctx.fillStyle='#37474F';ctx.strokeStyle='#2C1810';ctx.lineWidth=2;
    ctx.fillRect(-22*s,-75*s,44*s,8*s);ctx.strokeRect(-22*s,-75*s,44*s,8*s);
    ctx.fillRect(-14*s,-100*s,28*s,27*s);ctx.strokeRect(-14*s,-100*s,28*s,27*s);
  }
  ctx.restore();
}

