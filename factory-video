  // Output label
  const fade=Math.min(1,Math.max(0,(sTime-2)/2));
  ctx.globalAlpha=fade;
  ctx.fillStyle='rgba(76,175,80,0.15)';ctx.strokeStyle='#4CAF50';ctx.lineWidth=3;
  ctx.beginPath();ctx.roundRect(W*0.04,H*0.28,W*0.92,H*0.5,12);ctx.fill();ctx.stroke();
  comicLabel('×3.4 OUTPUT  🚀  -68% DOWNTIME',W*0.5,H*0.87,'#2E7D32',20);
  ctx.globalAlpha=1;
  // confetti particles
  if(Math.random()<0.08){
    addParticle(Math.random()*W,H*0.3,
      `hsl(${Math.random()*360},90%,60%)`,
      (Math.random()-0.5)*3,Math.random()*2+1,3,5);
  }
}

// ═══════════════════════════════════════════
// MAIN DRAW
// ═══════════════════════════════════════════
function draw(){
  ctx.clearRect(0,0,W,H);
  const fade=Math.min(1,sTime*2);
  ctx.globalAlpha=fade;
  switch(SCENES[scene].type){
    case 'water':         drawScene0();break;
    case 'water_problem': drawScene1();break;
    case 'electric_swap': drawScene2();break;
    case 'bad_results':   drawScene3();break;
    case 'eureka':        drawScene4();break;
    case 'reimagined':    drawScene5();break;
  }
  ctx.globalAlpha=1;
  drawParticles();
}

// ═══════════════════════════════════════════
// BOB BOUNCE
// ═══════════════════════════════════════════
function updateBob(dt){
  bobBounceV+=dt*18;
  bobBounce+=bobBounceV*dt;
  if(bobBounce>0){bobBounce=0;bobBounceV=-Math.abs(bobBounceV)*0.4;}
  if(Math.abs(bobBounceV)<0.5 && bobBounce>=0) bobBounceV=0;
}

// ═══════════════════════════════════════════
// UI
// ═══════════════════════════════════════════
function showSpeech(text,x,y){
  const el=document.getElementById('speech');
  el.textContent=text;
  el.style.left=x+'px';el.style.top=y+'px';
  el.classList.add('show');
}
function hideSpeech(){document.getElementById('speech').classList.remove('show');}

function showComicFx(text,x,y){
  const el=document.getElementById('comic-fx');
  el.textContent=text;el.style.left=x+'px';el.style.top=y+'px';
  el.classList.add('pop');
  setTimeout(()=>el.classList.remove('pop'),1200);
}

function updateUI(){
  const sc=SCENES[scene];
  // Chapter
  const ch=document.getElementById('chapter');
  ch.textContent=`Scene ${scene+1}/6  •  ${sc.title}`;
  if(sTime>0.3) ch.classList.add('show'); else ch.classList.remove('show');
  // Narration
  const nar=document.getElementById('narration');
  document.getElementById('nar-text').textContent=sc.narration;
  if(sTime>1.2) nar.classList.add('show'); else nar.classList.remove('show');
  // Speech bubble timing
  if(sc.speech && sTime>sc.speechDelay && sTime<sc.speechDelay+6){
    showSpeech(sc.speech, W*0.14, H*0.55);
  } else hideSpeech();
  // Comic FX
  if(sc.comicFx && Math.abs(sTime-sc.comicDelay)<0.05){
    showComicFx(sc.comicFx, W*0.5-60, H*0.35);
  }
  // Metrics
  const mp=document.getElementById('metrics-popup');
  if(sc.metrics && sTime>3){
    mp.classList.add('show');
    document.getElementById('mv-out').textContent=sc.metrics.out;
    document.getElementById('mv-out').className='mval '+sc.metrics.outC;
    document.getElementById('mv-eng').textContent=sc.metrics.eng;
    document.getElementById('mv-eng').className='mval '+sc.metrics.engC;
    document.getElementById('mv-dwn').textContent=sc.metrics.dwn;
    document.getElementById('mv-dwn').className='mval '+sc.metrics.dwnC;
  } else mp.classList.remove('show');
  // Progress
  let elapsed=0;
  for(let i=0;i<scene;i++) elapsed+=SCENES[i].dur;
  elapsed+=sTime;
  document.getElementById('prog-fill').style.width=(elapsed/TOTAL_DUR*100)+'%';
  const s=Math.floor(elapsed),m=Math.floor(s/60),ss=s%60;
  document.getElementById('timer').textContent=`${m}:${ss<10?'0'+ss:ss}`;
  // Dots
  document.querySelectorAll('.sdot').forEach((d,i)=>{
    d.className='sdot'+(i===scene?' active':i<scene?' done':'');
  });
  document.getElementById('scene-num-display')&&
    (document.getElementById('scene-num-display').textContent=scene+1);
}

// ═══════════════════════════════════════════
// LOOP
// ═══════════════════════════════════════════
let raf;
function loop(ts){
  if(lastTs===null) lastTs=ts;
  const dt=Math.min((ts-lastTs)/1000,0.05);
  lastTs=ts;
  if(playing){
    sTime+=dt; totalTime+=dt; animT+=dt;
    updateBob(dt);
    updateParticles(dt);
    if(sTime>=SCENES[scene].dur){
      if(scene<SCENES.length-1) gotoScene(scene+1);
      else { playing=false; document.getElementById('playbtn').textContent='▶ Replay'; }
    }
  }
  draw();
  updateUI();
  raf=requestAnimationFrame(loop);
}

// ═══════════════════════════════════════════
// CONTROLS
// ═══════════════════════════════════════════
function buildDots(){
  const c=document.getElementById('dots');c.innerHTML='';
  SCENES.forEach((_,i)=>{
    const d=document.createElement('div');
    d.className='sdot'+(i===scene?' active':i<scene?' done':'');
    d.onclick=()=>gotoScene(i);c.appendChild(d);
  });
}
buildDots();

function gotoScene(i){
  scene=Math.max(0,Math.min(SCENES.length-1,i));
  sTime=0;animT=0;lastTs=null;
  particles=[];sparks=[];waterDrops=[];
  bobBounce=-8;bobBounceV=-12;
  hideSpeech();
  document.getElementById('metrics-popup').classList.remove('show');
  document.getElementById('chapter').classList.remove('show');
  document.getElementById('narration').classList.remove('show');
  buildDots();
}
function prevScene(){if(scene>0)gotoScene(scene-1);}
function nextScene(){if(scene<SCENES.length-1)gotoScene(scene+1);}
function togglePlay(){
  playing=!playing;lastTs=null;
  const b=document.getElementById('playbtn');
  if(playing){
    if(scene===SCENES.length-1&&sTime>=SCENES[scene].dur) gotoScene(0);
    b.textContent='⏸ Pause';
  } else b.textContent='▶ Play';
}
function startVideo(){
  document.getElementById('title-card').classList.add('gone');
  playing=true;started=true;
  requestAnimationFrame(loop);
}
document.addEventListener('keydown',e=>{
  if(e.key===' '){e.preventDefault();if(!started)startVideo();else togglePlay();}
  if(e.key==='ArrowRight') nextScene();
  if(e.key==='ArrowLeft')  prevScene();
});
// Click canvas to play/pause
document.getElementById('scene').addEventListener('click',()=>{if(started)togglePlay();});
// Start render loop for title card preview
requestAnimationFrame(function preview(ts){
  resize(); draw();
  if(!started) requestAnimationFrame(preview);
});
</script>
</body>
</html>
